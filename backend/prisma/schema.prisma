datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Session {
  id        String   @id @default(cuid())
  sid       String   @unique
  data      String
  expires   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Users
model User {
  id          Int        @id @default(autoincrement())
  name        String
  email       String    @unique
  password    String
  img         String?
  files       File[]
  members     Member[]
  linkedAccounts LinkedAccount[]
  messages    Message[]
  privateChats PrivateChat[]
  aiPrompt  String?
  aiPersonality String? 
}

// Groups
model Group {
  id             Int       @id @default(autoincrement())
  name           String
  img            String?
  members        Member[]
  files          File[]
  channels       Channel[]
  groupSources   GroupSource[]
  groupAiModels  GroupAiModel[]
  privateChats   PrivateChat[]
  inviteToken    String? @unique
  aiPrompt  String?
  aiPersonality String?
}

// Chunks
model Chunk {
  id        Int    @id @default(autoincrement())
  fileName  String
  text      String
  vector    Json
  relations String?
  entities  String?
  file      File   @relation(fields: [fileId], references: [id])
  fileId    Int
}

// Files
model File {
  id        Int      @id @default(autoincrement())
  name      String
  path      String
  mimeType  String
  size      Int
  info      String?

  group     Group    @relation(fields: [groupId], references: [id])
  groupId   Int

  user      User     @relation(fields: [userId], references: [id])
  userId    Int

  remoteId  String?
  sourceId  Int?
  isLinked  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks    Chunk[]
}

// Members
model Member {
  id      Int    @id @default(autoincrement())
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId Int
  user    User   @relation(fields: [userId], references: [id])
  userId  Int
  role    MemberRole

  @@unique([groupId, userId])
  
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

// Sources
model Source {
  id        Int     @id @default(autoincrement())
  name      String
  groupSources GroupSource[]
}

// Pivot: GroupSource
model GroupSource {
  id       Int    @id @default(autoincrement())
  group    Group  @relation(fields: [groupId], references: [id])
  groupId  Int
  source   Source @relation(fields: [sourceId], references: [id])
  sourceId Int
}

// Channels
model Channel {
  id       Int      @id @default(autoincrement())
  name     String
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId  Int
  messages Message[]
  aiPrompt  String?
  aiPersonality String? 
}

// Messages
model Message {
  id             Int       @id @default(autoincrement())
  isAi           Boolean   @default(false)
  channel        Channel?  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId      Int?
  privateChat    PrivateChat?   @relation(fields: [privateChatId], references: [id], onDelete: Cascade)
  privateChatId  Int?
  user           User      @relation(fields: [userId], references: [id])
  userId         Int
  createdAt      DateTime  @default(now())
  content        String
  isPinned       Boolean   @default(false)
  parentMessage  Message?  @relation("MessageReplies", fields: [parentMessageId], references: [id])
  parentMessageId Int?
  replies        Message[] @relation("MessageReplies")
}

// Private Channels / Chats
model PrivateChat {
  id        Int    @id @default(autoincrement())
  name      String
  user      User   @relation(fields: [userId], references: [id])
  userId    Int
  group     Group  @relation(fields: [groupId], references: [id])
  groupId   Int
  messages  Message[]
  aiPrompt  String?
  aiPersonality String?
}

// Linked Accounts
model LinkedAccount {
  id           Int      @id @default(autoincrement())
  userId       Int
  provider     String
  providerUser String
  email        String?
  accessToken  String
  refreshToken String
  expiresAt    DateTime

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerUser])
}

// AI Models
model AiModel {
  id          Int    @id @default(autoincrement())
  name        String
  groupAiModels GroupAiModel[]
}

// Pivot: Group-AI Model
model GroupAiModel {
  id        Int      @id @default(autoincrement())
  groupId   Int
  aiModelId Int
  group     Group    @relation(fields: [groupId], references: [id])
  aiModel   AiModel  @relation(fields: [aiModelId], references: [id])
}